                    <option value="-XX:+UseG1GC"/>
                    <option value="-XX:+ExplicitGCInvokesConcurrent"/>
                    <option value="-XX:MaxGCPauseMillis=500"/>
                    <option value="-verbose:gc"/>
                    <option value="-XX:+UseCompressedOops"/>
                    <option value="-XX:-UseCompressedClassPointers"/>
                    <option value="-XX:+HeapDumpOnOutOfMemoryError"/>
